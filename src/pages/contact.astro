---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'まずは30分、状況を聞かせてください｜Meandle';
const description = 'Meandleの相談窓口です。意味設計と8フィールド構造についての対話の場として、お気軽にお声がけください。';

// SSGformの送信先 ─ 実URLが決まったらここを書き換える
const FORM_ENDPOINT = 'https://ssgform.com/s/REPLACE_WITH_YOUR_SSGFORM_ID';

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://meandle.jp/" },
    { "@type": "ListItem", "position": 2, "name": "相談する", "item": "https://meandle.jp/contact/" }
  ]
};

const contactLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Meandle 相談窓口",
  "url": "https://meandle.jp/contact/",
  "inLanguage": "ja"
};
---

<BaseLayout title={title} description={description} jsonLd={[breadcrumbLd, contactLd]}>
  <section class="section">
    <div class="container" style="max-width:720px">
      <nav class="breadcrumb"><a href="/">ホーム</a>　/　相談する</nav>
      <span class="eyebrow">Contact</span>
      <h1>まずは30分、状況を<br/>聞かせてください。</h1>
      <p class="lead">事業の言語を整理する壁打ちの場としてご活用ください。提案や売り込みはいたしません。<br/>内容を拝見し、2営業日以内にご連絡します。</p>

      <form class="form mt-6" action={FORM_ENDPOINT} method="POST">
        <div class="form-field">
          <label for="company">会社名 <span class="req">必須</span></label>
          <input id="company" name="会社名" type="text" required autocomplete="organization"/>
        </div>
        <div class="form-field">
          <label for="name">お名前 <span class="req">必須</span></label>
          <input id="name" name="お名前" type="text" required autocomplete="name"/>
        </div>
        <div class="form-field">
          <label for="email">メールアドレス <span class="req">必須</span></label>
          <input id="email" name="メールアドレス" type="email" required autocomplete="email"/>
        </div>
        <div class="form-field">
          <label for="tel">電話番号</label>
          <input id="tel" name="電話番号" type="tel" autocomplete="tel" inputmode="tel"/>
        </div>
        <div class="form-field">
          <label for="msg">相談内容 <span class="req">必須</span></label>
          <textarea id="msg" name="相談内容" rows="6" required placeholder="現在の事業状況や、感じている課題などを率直にお書きください。"></textarea>
        </div>
        <input type="hidden" name="送信元" value="meandle.jp/contact/"/>
        <button type="submit" class="btn btn--brand btn--lg">送信する</button>
        <p class="muted" style="font-size:12.5px; margin-top:0">送信前に、当ページ末尾の取り扱いについて同意いただいたものとみなします。</p>
      </form>

      <hr style="margin:48px 0 32px; border:0; border-top:1px solid var(--line)"/>
      <h3 style="font-size:16px">取り扱いについて</h3>
      <p class="muted" style="font-size:13px; margin-bottom:0">いただいたご相談内容は、ご返信およびサービス案内の目的のみに使用し、第三者への提供は行いません。</p>
    </div>
  </section>
</BaseLayout>
