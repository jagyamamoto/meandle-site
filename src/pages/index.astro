---
import BaseLayout from '../layouts/BaseLayout.astro';
import nav from '../data/navigation.json';

const title = '資料請求は来る。でも商談にならない理由を、意味から整える｜Meandle';
const description = 'Meandleは、Jag Yamamoto / Jag Projectが開発・監修する意味設計ソリューションです。事業・プロダクト・マーケティング・コンテンツの4領域で、8フィールド構造により売るべき意味を定義し、商談化、営業導線、AI検索時代の文脈整合を支援します。';
const ogTitle = '資料請求は来る。でも、商談にならない。｜Meandle';
const ogDescription = '原因は流入でもデザインでもありません。売るべき意味が定義されていないからです。Meandleは、8フィールド構造で事業の意味を整えるB2B意味設計ソリューションです。';

const SUPERVISOR = { name: 'Jag Yamamoto', org: 'Jag Project', url: 'https://jagproject.com/' };

const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Meandle",
  "alternateName": ["みんどる", "Mean Handle"],
  "url": "https://meandle.jp",
  "logo": "https://meandle.jp/images/logo.png",
  "description": description,
  "areaServed": "JP",
  "founder": { "@type": "Person", "name": SUPERVISOR.name },
  "parentOrganization": { "@type": "Organization", "name": SUPERVISOR.org, "url": SUPERVISOR.url },
  "sameAs": [SUPERVISOR.url]
};

const serviceLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "意味設計コンサルティング",
  "provider": { "@type": "Organization", "name": "Meandle", "url": "https://meandle.jp" },
  "areaServed": "JP",
  "description": "事業・プロダクト・マーケティング・コンテンツの4領域で、売るべき意味を8フィールド構造により定義し、商談化・営業導線・AI検索時代の文脈整合を支援するB2B意味設計サービス。",
  "offers": [
    { "@type": "Offer", "name": "Meandle Package S",   "price": "500000",  "priceCurrency": "JPY", "description": "意味設計の初動パッケージ" },
    { "@type": "Offer", "name": "Meandle Package M",   "price": "1500000", "priceCurrency": "JPY", "description": "標準パッケージ／6週間" },
    { "@type": "Offer", "name": "Meandle Package L",   "price": "5000000", "priceCurrency": "JPY", "description": "複数事業／12週間" },
    { "@type": "Offer", "name": "Be Meandling Basic",  "price": "600000",  "priceCurrency": "JPY", "description": "月次伴走" },
    { "@type": "Offer", "name": "Be Meandling Full",   "price": "1500000", "priceCurrency": "JPY", "description": "週次伴走" }
  ]
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "「Meandle（みんどる）」とは何ですか？", "acceptedAnswer": { "@type": "Answer", "text": "Mean（意味）に Handle（取り扱う）を組み合わせた造語で、「意味にハンドルを付けて、扱える形にする」という行為そのものを指します。動詞化したものが「みんどる」です。" }},
    { "@type": "Question", "name": "Web制作も依頼できますか？", "acceptedAnswer": { "@type": "Answer", "text": "MeandleはWeb制作会社ではありません。意味の定義と運用設計に特化しています。制作の実行が必要な場合は、制作パートナーと連携して進めることも可能です。" }},
    { "@type": "Question", "name": "SEO記事の代行はしてもらえますか？", "acceptedAnswer": { "@type": "Answer", "text": "個別記事の代筆を主目的にはしていません。代わりに、8フィールド構造で意味の地図を引き、貴社や制作チームが一貫した意味で発信できる設計図を残します。" }},
    { "@type": "Question", "name": "効果はどれくらいで出ますか？", "acceptedAnswer": { "@type": "Answer", "text": "意味の再定義そのものは4週間〜の設計で輪郭を立ち上げます。市場での反応は、運用反映から1〜3か月で現れ始めるケースが多い領域です。ただし成果を保証するものではありません。" }},
    { "@type": "Question", "name": "AI検索（AIO）にどう対応しますか？", "acceptedAnswer": { "@type": "Answer", "text": "個別最適化のテクニックではなく、AIが文脈の整合性を取りやすい意味の供給を設計します。結果としてAI検索でも引用・要約されやすい状態を狙います。" }},
    { "@type": "Question", "name": "AIに正しく引き当てられない場合は対応できますか？", "acceptedAnswer": { "@type": "Answer", "text": "対応します。AIに引き当てられない原因の多くは、コンテンツの量や個別最適化のテクニックではなく、意味の供給構造そのものにあります。8フィールドで自社の文脈の島を組み直し、AI検索から引用・要約される状態へ設計し直します。" }},
    { "@type": "Question", "name": "途中で方向を変えたくなったら？", "acceptedAnswer": { "@type": "Answer", "text": "方向転換は前提です。各フェーズの末尾で意味モデルを再点検し、must / must_not を更新する作りになっています。" }}
  ]
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://meandle.jp/" }
  ]
};

const eightFields = [
  { name: "ジョブ",     desc: "顧客が片づけたい本当の用件",                         type: "ctx" },
  { name: "シーン",     desc: "その用件が立ち上がる場面と時間",                     type: "ctx" },
  { name: "代替案",     desc: "現在使われている解決手段（含：何もしない）",         type: "ctx" },
  { name: "比較軸",     desc: "選ばれるときに使われる判断のものさし",               type: "ctx" },
  { name: "価値",       desc: "比較軸の上で我々が固有に提供できる便益",             type: "ctx" },
  { name: "証拠",       desc: "信じてもらうための根拠と数字",                       type: "ctx" },
  { name: "must",       desc: "決して外せない約束。文脈の中核",                     type: "must" },
  { name: "must_not",   desc: "決して該当しない／提供しないこと",                   type: "mustnot" }
];

const domains = [
  {
    idx: "01", label: "事業",
    title: "事業・事業課題をみんどる",
    desc: "事業の見える化をするうえで、何が見えていないかも明確にします。変えるべき部分と、そのままの部分を整理し、社内・事業部内・顧客に対して方向性を共通言語化。どこがズレると成功するのか、どうズレると上手くいかないのか――その構造を把握することで、事業の最大効果が出せる形に導きます。"
  },
  {
    idx: "02", label: "プロダクト",
    title: "ソリューション・プロダクトをみんどる",
    desc: "競合製品との差別化において、競合にあって自社にない部分を弱みではなく意味として捉え直します。単純な比較ではなく、プロダクトの「個性」をエンドユーザー・バイヤー・ディストリビュータに「強さ」として伝わる形に整えます。"
  },
  {
    idx: "03", label: "マーケティング",
    title: "Webマーケティング／B2Bマーケティングをみんどる",
    desc: "競合・ベンチマーク・市場背景をみんどり、自社をみんどったものと比較・分析。ブレない方向性をつくり、ブレていく様子自体もみんどっていくことで、どこが成功方程式かを見つけ、成功確率を高めていきます。"
  },
  {
    idx: "04", label: "コンテンツ",
    title: "Webコンテンツをみんどる",
    desc: "潜在的なユーザーに正しく届くために、AIがしっかり把握できる形に整えます。必要のない問い合わせを減らし、これまでリーチできていなかった層にも、誤解なく適切に届けることが可能になります。"
  }
];

const blogPosts = nav.blog;
---
<BaseLayout
  title={title}
  description={description}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  jsonLd={[orgLd, serviceLd, faqLd, breadcrumbLd]}
>

  <!-- 1. Hero -->
  <section class="hero">
    <div class="container">
      <span class="eyebrow">Business Meaning Design / Meandle</span>
      <h1>資料請求は来る。<br/>でも、<span class="accent">商談にならない。</span></h1>
      <p class="lead">原因は流入でも、デザインでもありません。<br/>「売るべき意味」が、まだ定義されていないからです。</p>
      <p class="lead lead--pc">Meandleは、事業・プロダクト・マーケティング・コンテンツの4領域で、売るべき意味を8フィールドに分解し、社内・顧客・営業・Web・AIが同じ意味を扱える状態をつくる意味設計ソリューションです。</p>
      <p class="lead lead--sp">資料請求は来る。でも商談にならない。<br/>その原因は、売るべき意味がまだ定義されていないことかもしれません。</p>
      <div class="flex-row mt-4">
        <a href="/contact/" class="btn btn--brand btn--lg">まずは30分、状況を聞かせてください</a>
        <a href="#about" class="btn btn--ghost">「みんどる」とは？</a>
      </div>
    </div>
  </section>

  <!-- 2. Meandleとは -->
  <section class="section section--mint" id="about">
    <div class="container" style="max-width:840px">
      <span class="eyebrow">About Meandle</span>
      <h2>Meandleとは、意味にハンドルを付けること。</h2>

      <p>意味は、頭のなかにあるうちは触れません。<br/>書き出して、並べ替えて、運用に渡せる形になって、ようやく事業を動かせます。</p>

      <p>Meandleは、誰に、何を、なぜ選ばれるのか。<br/>何を約束し、何を約束しないのか。<br/>競合と何が違い、どの文脈なら商談になるのか。</p>

      <p>その輪郭を <strong>8フィールドで定義し、事業・プロダクト・マーケティング・コンテンツへ渡せる形にする</strong> ための方法です。</p>

      <div class="card mt-4" style="background:rgba(255,249,237,0.7); border-color:rgba(18,36,44,0.12)">
        <div class="subhead" style="margin-top:0">語源</div>
        <p style="margin:0; font-size:17px"><strong>Meandle ＝ Mean ＋ Handle</strong>　<span style="color:var(--brand-deep)">意味に、ハンドルを付ける。</span></p>
        <p style="margin:8px 0 0; font-size:14.5px; color:var(--ink-soft)">動詞化したものが、Meandle のコア動詞「みんどる」です。</p>
      </div>

      <p class="muted" style="font-size:13.5px; margin-top:18px">
        ※ <strong>Be Meandling</strong> は、一度意味を定義して終わりではなく、市場・顧客・自社の更新に合わせて、<strong>意味をみんどり続ける状態</strong>です。
      </p>
    </div>
  </section>

  <!-- 3. must / must_not -->
  <section class="section section--paper" id="mustnot">
    <div class="container">
      <span class="eyebrow">Principle</span>
      <h2>must と must_not を、同じ重みで併記する。</h2>
      <p class="lead">多くのブランド戦略は「やること」だけを語ります。<br/>Meandleは「決してやらないこと」を、同じ強さで定義します。</p>
      <p class="lead" style="font-weight:600; color:var(--brand-deep)">意味は、足すだけでは強くなりません。削ることで、はじめて輪郭が立ちます。</p>
      <div class="grid grid--2 mt-4">
        <div class="card">
          <h3 class="brand-fg" style="margin-top:0">なぜ must だけでは不十分なのか</h3>
          <p>提供価値の足し算では、競合と意味が混ざります。「やらないこと」がない意味の地図は、顧客にとってもAI検索にとっても、輪郭が見えません。</p>
        </div>
        <div class="card">
          <h3 class="brand-fg" style="margin-top:0">must_not がもたらす効果</h3>
          <p>輪郭が立ち上がると、誤った入口が減ります。本当に響く相手に深く届き、商談化しやすい文脈へ移行できます。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Self-check -->
  <section class="section" id="diagnose">
    <div class="container">
      <span class="eyebrow">Self-check</span>
      <h2>あてはまるものに、チェックしてみてください。</h2>
      <p class="lead">ひとつでも当てはまるなら、施策を増やす前に、意味の輪郭を整える価値があります。</p>
      <div class="checks mt-4">
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>資料請求はあるが、商談にならない</strong><span>関心は喚起できているが、意味の輪郭が立っていない。</span></div></label>
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>KPIは追えているが、KGIが動かない</strong><span>露出と売上のあいだに、因果の橋がかかっていない。</span></div></label>
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>AI検索からの流入が読めない</strong><span>個別最適化ではなく、文脈の供給設計が必要な状態。</span></div></label>
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>コンテンツを量産したが、事業が動かない</strong><span>must_not が無く、意味が拡散している。</span></div></label>
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>競合との違いを言葉にできない</strong><span>比較軸と must_not が言語化されておらず、輪郭がぼやけている。</span></div></label>
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>AIに自社サービスが正しく引き当てられない</strong><span>「文脈の島」が立ち上がっておらず、AIが要約から拾えない状態。</span></div></label>
      </div>
    </div>
  </section>

  <!-- 5. 4 Domains -->
  <section class="section section--paper" id="domains">
    <div class="container">
      <span class="eyebrow">4 Domains</span>
      <h2>4つの領域で、意味を引き直す。</h2>
      <p class="lead">同じ「意味」を、解像度を変えて4つの層で扱います。<br/>どの層から始めても、隣の層に必ず接続します。</p>
      <div class="grid grid--2 mt-4">
        {domains.map((d) => (
          <div class="card">
            <div style="font-size:11px; color:var(--brand-deep); letter-spacing:.18em; font-weight:700; margin-bottom:8px">DOMAIN {d.idx}　{d.label}</div>
            <h3 style="margin-top:6px; font-size:18px; line-height:1.55">{d.title}</h3>
            <p style="font-size:14px; color:var(--ink-soft); margin:12px 0 0; line-height:1.85">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. KPI/KGIが動かない3段階 -->
  <section class="section section--card" id="kpi">
    <div class="container">
      <span class="eyebrow">Why KGI not moving</span>
      <h2>数字が動かないとき、原因はたいてい上流にあります。</h2>
      <p class="lead">流入を増やしても、記事を増やしても、商談が増えない。<br/>そのとき見るべきなのは、数字の手前にある<strong>意味の構造</strong>です。</p>
      <div class="viz-flow mt-4">
        <div class="viz-flow__node">意味の不在<small>「何を売っているか」の定義がない</small></div>
        <div class="viz-flow__arrow">→</div>
        <div class="viz-flow__node">文脈の空洞化<small>露出は増えても、検索意図に届かない</small></div>
        <div class="viz-flow__arrow">→</div>
        <div class="viz-flow__node">KGIの停滞<small>流入はあるが、商談化しない</small></div>
      </div>
      <p class="mt-3" style="text-align:center; font-weight:600; color:var(--brand-deep)">Meandleが扱うのは、数字の手前にある「意味の構造」です。</p>
    </div>
  </section>

  <!-- 7. Evidence -->
  <section class="section section--mint" id="results">
    <div class="container">
      <span class="eyebrow">Evidence</span>
      <h2>意味を整えると、AIに引き当てられやすくなる。</h2>
      <p class="lead">8フィールドで意味を <strong>みんどり</strong>、文脈の島を組み直したあと、同じクエリ集合に対して、AIが主題を正しく引き当てる確率が変化しました。</p>
      <div class="grid grid--2 mt-4" style="align-items:center">
        <div>
          <div class="bignum"><span>63.3%</span><sub>→</sub><span>90.0%</span></div>
          <p class="mt-2" style="font-weight:700; font-size:17px">Top-1 正解率</p>
          <p class="muted" style="font-size:13.5px">同一クエリ集合に対する、みんどる前後の比較。母集団・設計を揃えた対称検証。</p>
        </div>
        <div class="card">
          <h3 style="margin-top:0">検定結果</h3>
          <ul style="list-style:none; padding:0; margin:0; font-size:14.5px; line-height:1.95">
            <li><strong>Boschloo検定</strong>　p = 0.015</li>
            <li><strong>Cohen's h</strong>　0.657</li>
            <li><strong>サンプル</strong>　単一カテゴリ・対称設計</li>
          </ul>
          <p class="muted mt-2" style="font-size:12px; margin-bottom:0">※ この数値は特定条件下の内部検証であり、すべての事業・検索環境で同じ結果を保証するものではありません。</p>
        </div>
      </div>
      <p class="mt-3" style="font-size:14.5px; max-width:780px; color:var(--ink-soft)">
        AIは、単語の量だけでなく、<strong>文脈の整合</strong>を見ています。8フィールドで意味の供給構造を整えることで、AIが主題を拾いやすい状態を作ります。
      </p>
    </div>
  </section>

  <!-- 8. 8 Fields -->
  <section class="section" id="eightfields">
    <div class="container">
      <span class="eyebrow">8 Fields</span>
      <h2>意味は、8つのフィールドで定義できる。</h2>
      <p class="lead">この8項目は、社内会議のためだけの表ではありません。<br/>営業、マーケティング、Web制作、AI検索が、<strong>同じ意味を扱うための地図</strong>です。</p>
      <div class="table-wrap mt-4">
        <table class="table fields-table">
          <thead><tr><th style="width:28%">フィールド</th><th>定義</th></tr></thead>
          <tbody>
            {eightFields.map((f) => (
              <tr class={f.type === 'must' ? 'row-must' : f.type === 'mustnot' ? 'row-mustnot' : ''}>
                <td><strong>{f.name}</strong></td>
                <td>{f.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- 9. Authority + 監修/運営元 -->
  <section class="section section--paper" id="authority">
    <div class="container">
      <span class="eyebrow">Authority</span>
      <h2>設計の根拠</h2>
      <div class="notice mt-4">
        <div>
          <h3>6年以上の運用実績</h3>
          <p>Meandleは、{SUPERVISOR.name} / {SUPERVISOR.org}が実務で積み重ねてきた、事業定義、商品企画、B2Bウェブマーケティング、メディア設計の知見を、意味設計として体系化したものです。</p>
        </div>
        <div>
          <h3>教育現場での実装</h3>
          <p>武蔵野美術大学にて非常勤講師として、意味設計と表現の接続を実践的に指導しています。</p>
        </div>
      </div>

      <div style="margin-top:20px; padding:16px 22px; background:var(--card); border-radius:12px; border:1px solid var(--line); display:flex; flex-wrap:wrap; gap:8px 28px; align-items:baseline; font-size:14px">
        <span><strong>監修</strong>：{SUPERVISOR.name}</span>
        <span><strong>運営元</strong>：<a href={SUPERVISOR.url} rel="noopener" target="_blank" style="color:var(--brand-deep); font-weight:700; text-decoration:underline">{SUPERVISOR.org}</a></span>
        <a href="/about/" style="color:var(--brand-deep); font-weight:700; margin-left:auto">監修者・運営元について →</a>
      </div>

      <!-- 関連論考：「意味へのハンドル付け理論」公開後にリンク追加 -->
    </div>
  </section>

  <!-- 10. Story -->
  <section class="section" id="story">
    <div class="container" style="max-width:820px">
      <span class="eyebrow">Story</span>
      <h2>Meandleが生まれた背景</h2>
      <p style="font-style:italic; color:var(--brand-deep); font-size:17px">私は、Webの数字だけを見ていても、商談にならない理由は分からないと思っています。</p>
      <p>「資料請求はある。でも商談化しない」。何十社のB2Bサイトを設計・運用するなかで、繰り返し見てきた症状です。</p>
