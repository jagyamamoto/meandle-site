          </div>
        </fieldset>
        <fieldset class="estimate__q">
          <legend>Q3. 運用は誰が担いますか？</legend>
          <div class="estimate__opts">
            <label><input type="radio" name="ops" value="1"/><span>自社で</span></label>
            <label><input type="radio" name="ops" value="2"/><span>月次で半伴走</span></label>
            <label><input type="radio" name="ops" value="3"/><span>週次で深く入ってほしい</span></label>
          </div>
        </fieldset>
        <div class="estimate__result" id="estimateResult">3問にお答えいただくと、目安プランを表示します。</div>
      </div>
    </div>
  </section>
  <script is:inline>
    (function () {
      var box = document.getElementById('estimateBox');
      var out = document.getElementById('estimateResult');
      if (!box || !out) return;
      function score() {
        var biz = box.querySelector('input[name="biz"]:checked');
        var dur = box.querySelector('input[name="dur"]:checked');
        var ops = box.querySelector('input[name="ops"]:checked');
        if (!biz || !dur || !ops) return;
        var b = +biz.value, d = +dur.value, o = +ops.value;
        var sum = b + d;
        var plan;
        if (o === 3) plan = 'Be Meandling Full（月150万円〜）';
        else if (o === 2) plan = 'Be Meandling Basic（月60万円〜）';
        else if (sum >= 5) plan = 'Meandle Package L（500万円〜）';
        else if (sum >= 3) plan = 'Meandle Package M（150万円〜）';
        else plan = 'Meandle Package S（50万円〜）';
        out.textContent = '目安：' + plan + '　─ 詳細はお話ししながら最適化します。';
      }
      box.addEventListener('change', score);
    })();</script>

