---
import BaseLayout from '../layouts/BaseLayout.astro';
import nav from '../data/navigation.json';

const title = '資料請求は来る。でも、商談にならない｜Meandle';
const description = '売るべき意味を定義し、事業を拓くための補助線。事業・プロダクト・マーケティング・コンテンツの4領域で、8フィールド構造で意味設計と運用を支援するB2Bコンサルティング。';

const SUPERVISOR = { name: 'Jag Yamamoto', org: 'Jag Project', url: 'https://www.jagproject.com/' };

const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Meandle",
  "alternateName": ["みんどる", "Mean Handle"],
  "url": "https://meandle.jp",
  "logo": "https://meandle.jp/images/logo.png",
  "description": description,
  "areaServed": "JP",
  "founder": { "@type": "Person", "name": SUPERVISOR.name },
  "parentOrganization": { "@type": "Organization", "name": SUPERVISOR.org, "url": SUPERVISOR.url },
  "sameAs": [SUPERVISOR.url]
};

const serviceLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "意味設計コンサルティング",
  "provider": { "@type": "Organization", "name": "Meandle", "url": "https://meandle.jp" },
  "areaServed": "JP",
  "description": "事業・プロダクト・マーケティング・コンテンツの4領域で、売るべき意味を8フィールド構造で定義し、AI検索時代の発見と商談化を後押しする伴走・パッケージサービス。",
  "offers": [
    { "@type": "Offer", "name": "Meandle Package S",   "price": "500000",  "priceCurrency": "JPY", "description": "意味設計の初動パッケージ" },
    { "@type": "Offer", "name": "Meandle Package M",   "price": "1500000", "priceCurrency": "JPY", "description": "標準パッケージ／6週間" },
    { "@type": "Offer", "name": "Meandle Package L",   "price": "5000000", "priceCurrency": "JPY", "description": "複数事業／12週間" },
    { "@type": "Offer", "name": "Be Meandling Basic",  "price": "600000",  "priceCurrency": "JPY", "description": "月次伴走" },
    { "@type": "Offer", "name": "Be Meandling Full",   "price": "1500000", "priceCurrency": "JPY", "description": "週次伴走" }
  ]
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "「Meandle（みんどる）」とは何ですか？", "acceptedAnswer": { "@type": "Answer", "text": "Mean（意味）に Handle（取り扱う）を組み合わせた造語で、「意味にハンドルを付けて、扱える形にする」という行為そのものを指します。動詞化したものが「みんどる」です。" }},
    { "@type": "Question", "name": "Web制作も依頼できますか？", "acceptedAnswer": { "@type": "Answer", "text": "MeandleはWeb制作会社ではありません。意味の定義と運用設計に特化しています。制作の実行が必要な場合は、お付き合いのある制作パートナーをご紹介可能です。" }},
    { "@type": "Question", "name": "SEO記事の代行はしてもらえますか？", "acceptedAnswer": { "@type": "Answer", "text": "個別記事の代筆は行いません。代わりに8フィールド構造で意味の地図を引き、貴社の制作チームが自走できる設計図を残します。" }},
    { "@type": "Question", "name": "効果はどれくらいで出ますか？", "acceptedAnswer": { "@type": "Answer", "text": "意味の再定義そのものは4週間〜の設計で完了します。市場での反応は、運用反映から1〜3か月で現れ始めるケースが多い領域です。" }},
    { "@type": "Question", "name": "AI検索（AIO）にどのように対応しますか？", "acceptedAnswer": { "@type": "Answer", "text": "個別最適化のテクニックではなく、AIが文脈の整合性を取りやすい意味の供給を設計します。結果としてAI検索でも引用・要約されやすい状態を狙います。" }},
    { "@type": "Question", "name": "AIに正しく引き当てられない場合は対応できますか？", "acceptedAnswer": { "@type": "Answer", "text": "対応します。AIに引き当てられない原因の多くは、コンテンツの量や個別最適化のテクニックではなく、意味の供給構造そのものにあります。8フィールドで自社の文脈の島を組み直し、AI検索から引用・要約される状態へ設計し直します。" }},
    { "@type": "Question", "name": "途中で方向を変えたくなったら？", "acceptedAnswer": { "@type": "Answer", "text": "方向転換は前提です。各フェーズの末尾で意味モデルを再点検し、must / must_not を更新する作りになっています。" }}
  ]
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://meandle.jp/" }
  ]
};

const eightFields = [
  { name: "ジョブ",     desc: "顧客が片づけたい本当の用件",                         type: "ctx" },
  { name: "シーン",     desc: "その用件が立ち上がる場面と時間",                     type: "ctx" },
  { name: "代替案",     desc: "現在使われている解決手段（含: 何もしない）",         type: "ctx" },
  { name: "比較軸",     desc: "選ばれるときに使われる判断のものさし",               type: "ctx" },
  { name: "価値",       desc: "比較軸の上で我々が固有に提供できる便益",             type: "ctx" },
  { name: "証拠",       desc: "信じてもらうための根拠と数字",                       type: "ctx" },
  { name: "must",       desc: "決して外せない約束。文脈の中核",                     type: "must" },
  { name: "must_not",   desc: "決して該当しない／提供しないこと",                   type: "mustnot" }
];

const domains = [
  {
    idx: "01", label: "事業",
    title: "事業・事業課題をみんどる",
    desc: "事業の見える化をするうえで、何が見えていないかも明確にします。変えるべき部分と、そのままの部分を整理し、社内・事業部内・顧客に対して方向性を共通言語化。どこがズレると成功するのか、どうズレると上手くいかないのか――その構造を把握することで、事業の最大効果が出せる形に導きます。"
  },
  {
    idx: "02", label: "プロダクト",
    title: "ソリューション・プロダクトをみんどる",
    desc: "競合製品との差別化において、競合にあって自社にない部分を弱みではなく意味として捉え直します。単純な比較ではなく、プロダクトの「個性」をエンドユーザー・バイヤー・ディストリビュータに「強さ」として伝わる形に整えます。"
  },
  {
    idx: "03", label: "マーケティング",
    title: "Webマーケティング／B2Bマーケティングをみんどる",
    desc: "競合・ベンチマーク・市場背景をみんどり、自社をみんどったものと比較・分析。ブレない方向性をつくり、ブレていく様子自体もみんどっていくことで、どこが成功方程式かを見つけ、成功確率を高めていきます。"
  },
  {
    idx: "04", label: "コンテンツ",
    title: "Webコンテンツをみんどる",
    desc: "潜在的なユーザーに正しく届くために、AIがしっかり把握できる形に整えます。必要のない問い合わせを減らし、これまでリーチできていなかった層にも、誤解なく適切に届けることが可能になります。"
  }
];

const blogPosts = nav.blog;
---
<BaseLayout title={title} description={description} jsonLd={[orgLd, serviceLd, faqLd, breadcrumbLd]}>

  <!-- 1. Hero -->
  <section class="hero">
    <div class="container">
      <span class="eyebrow">B2B 意味設計 × AIO</span>
      <h1>資料請求は来る。<br/>でも、<span class="accent">商談にならない。</span></h1>
      <p class="lead">原因は流入でも、デザインでもありません。<br/>「売るべき意味」が定義されていないからです。</p>
      <p class="lead">Meandleは、8フィールド構造で事業の意味を再定義し、<br/><strong>事業・プロダクト・マーケティング・コンテンツの4領域</strong>で、勝ち筋を増幅する補助線を引き直します。</p>
      <div class="flex-row mt-4">
        <a href="/contact/" class="btn btn--brand btn--lg">まずは30分、状況を聞かせてください</a>
        <a href="#naming" class="btn btn--ghost">「みんどる」とは？</a>
      </div>
    </div>
  </section>

  <!-- 2. Naming / 語源 -->
  <section class="section section--mint" id="naming">
    <div class="container" style="max-width:840px">
      <span class="eyebrow">Naming</span>
      <h2 style="font-size:clamp(24px, 4.4vw, 36px)">Meandle ＝ Mean ＋ Handle<br/><span style="color:var(--brand)">──意味に、ハンドルを付ける。</span></h2>

      <p class="lead" style="margin-top:20px">
        <strong>Mean</strong>（意味）に <strong>Handle</strong>（取っ手・取り扱う）を組み合わせた造語。<br/>
        動詞化したものが、Meandle のコア動詞 <strong style="color:var(--brand-deep)">「みんどる」</strong>です。
      </p>

      <p>意味は、頭のなかにあるうちは触れません。書き出して、並べ替えて、運用に渡せる形になって、ようやく事業を動かせます。Meandle は「意味にハンドルを付ける」という、ひとつの作業を指す動詞でもあります。</p>

      <p>ハンドルが付いた意味は、誰が握っても同じ方向へ進められる。属人化された価値観ではなく、社内・パートナー・AI 検索の三者が同じ地図を共有できる状態へ。<strong>「みんどる」</strong>は、その状態をつくる行為のことです。</p>

      <p class="muted" style="font-size:13.5px; margin-top:24px; padding-top:16px; border-top:1px solid rgba(18,36,44,0.15)">
        ※ 伴走サービス名「<strong>Be Meandling</strong>」は、「ずっと Meandle し続けている状態」を指します。意味の地図は一度引いて終わりではなく、市場・顧客・自社の更新を反映させ続ける運用前提のものです。
      </p>
    </div>
  </section>

  <!-- 3. Meandleがユニークな理由 -->
  <section class="section section--paper" id="about">
    <div class="container">
      <span class="eyebrow">Why Meandle</span>
      <h2>must と must_not を、同じ重みで併記する。</h2>
      <p class="lead">多くのブランド戦略は「やること（must）」だけを語ります。<br/>Meandleは「決してやらないこと（must_not）」を、同じ強さで定義します。</p>
      <div class="grid grid--2 mt-4">
        <div class="card">
          <h3 class="brand-fg" style="margin-top:0">なぜ must だけでは不十分なのか</h3>
          <p>提供価値の足し算では、競合と意味が混ざります。「やらないこと」が無い意味の地図は、顧客にとってもAI検索にとっても、輪郭が見えません。</p>
        </div>
        <div class="card">
          <h3 class="brand-fg" style="margin-top:0">must_not がもたらす効果</h3>
          <p>輪郭が立ち上がり、商談化率が変わります。誤った入口を減らし、本当に響く相手に深く届く構造へ移行できます。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. 自己診断（6項目） -->
  <section class="section" id="diagnose">
    <div class="container">
      <span class="eyebrow">Self-check</span>
      <h2>あてはまるものに、チェックしてみてください。</h2>
      <p class="lead">1つでも当てはまるなら、意味の輪郭がぼやけている兆候です。</p>
      <div class="checks mt-4">
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>A. 資料請求はあるが、商談にならない</strong><span>関心は喚起できているが、意味の輪郭が立っていない。</span></div></label>
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>B. KPIは追えているがKGIが動かない</strong><span>露出と売上のあいだに、因果の橋がかかっていない。</span></div></label>
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>C. AI検索からの流入が読めない</strong><span>個別最適化ではなく、文脈の供給設計が必要な状態。</span></div></label>
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>D. コンテンツを量産したが事業が動かない</strong><span>must_not が無く、意味が拡散している。</span></div></label>
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>E. 競合との違いを言葉にできない</strong><span>比較軸と must_not が言語化されておらず、輪郭がぼやけている。</span></div></label>
        <label class="check"><input type="checkbox"/><div class="check__body"><strong>F. AIに自社サービスが正しく引き当てられない</strong><span>「文脈の島」が立ち上がっておらず、AIが要約から拾えない状態。</span></div></label>
      </div>
    </div>
  </section>

  <!-- 5. 4領域カード -->
  <section class="section section--paper" id="domains">
    <div class="container">
      <span class="eyebrow">4 Domains</span>
      <h2>4つの領域で、意味を引き直す。</h2>
      <p class="lead">同じ「意味」を、解像度を変えて4つの層で扱います。<br/>どの層から始めても、隣の層に必ず接続します。</p>
      <div class="grid grid--2 mt-4">
        {domains.map((d) => (
          <div class="card">
            <div style="font-size:11px; color:var(--brand-deep); letter-spacing:.18em; font-weight:700; margin-bottom:8px">DOMAIN {d.idx}　{d.label}</div>
            <h3 style="margin-top:6px; font-size:18px; line-height:1.55">{d.title}</h3>
            <p style="font-size:14px; color:var(--ink-soft); margin:12px 0 0; line-height:1.85">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. KPI/KGIが動かない理由 -->
  <section class="section section--card">
    <div class="container">
      <span class="eyebrow">Why KGI not moving</span>
      <h2>KPI/KGIが動かない3段階</h2>
      <p class="lead">数字が動かないとき、原因はたいてい上流にあります。</p>
      <div class="viz-flow mt-4">
        <div class="viz-flow__node">① 意味の不在<small>「何を売っているか」の定義がない</small></div>
        <div class="viz-flow__arrow">→</div>
        <div class="viz-flow__node">② 文脈の空洞化<small>露出は増えても、検索意図に届かない</small></div>
        <div class="viz-flow__arrow">→</div>
        <div class="viz-flow__node">③ KGIの停滞<small>流入はあるが、商談化しない</small></div>
      </div>
    </div>
  </section>

  <!-- 7. 効果データ（みんどる効果） -->
  <section class="section section--mint" id="results">
    <div class="container">
      <span class="eyebrow">Evidence</span>
      <h2>みんどると、AIに引き当てられる確率が、ここまで変わる。</h2>
      <p class="lead">8 フィールドで意味を <strong>みんどり</strong>、文脈の島を組み直したあと──同じクエリ集合に対して、AI が「この主題の正解はここ」と引き当てる確率は、<strong>63.3% から 90.0%</strong> へ。検定で有意な差です。</p>
      <div class="grid grid--2 mt-4" style="align-items:center">
        <div>
          <div class="bignum"><span>63.3%</span><sub>→</sub><span>90.0%</span></div>
          <p class="mt-2" style="font-weight:700; font-size:17px">Top-1 正解率（AI が最初に引き当てた率）</p>
          <p class="muted" style="font-size:13.5px">同一クエリ集合に対する、<strong>みんどる前後</strong>の比較。母集団・設計を揃えた対称検証。</p>
        </div>
        <div class="card">
          <h3 style="margin-top:0">検定結果</h3>
          <ul style="list-style:none; padding:0; margin:0; font-size:14.5px; line-height:1.95">
            <li><strong>Boschloo検定</strong>　p = 0.015</li>
            <li><strong>Cohen's h</strong>　0.657（中〜大の効果量）</li>
            <li><strong>サンプル</strong>　単一カテゴリ・対称設計</li>
          </ul>
          <p class="muted mt-2" style="font-size:12.5px; margin-bottom:0">※ 数値は内部検証に基づく一例であり、すべての事業で同じ結果が得られることを保証するものではありません。</p>
        </div>
      </div>
      <p class="muted mt-3" style="font-size:13px; max-width:780px">
        <strong>読み方</strong>：「Top-1 正解率」とは、AI が「ある主題の正解はこのサイト／このページ」と最初に提示する割合。これが上がるほど、AI 検索の入口で <strong>誤って素通りされる確率</strong> が下がります。意味をみんどることは、機能の追加ではなく <strong>引き当てられやすさそのもの</strong> を変える行為です。
      </p>
    </div>
  </section>

  <!-- 8. 8フィールド構造 -->
  <section class="section" id="eightfields">
    <div class="container">
      <span class="eyebrow">8 Fields</span>
      <h2>意味は、8つのフィールドで定義できる。</h2>
      <p class="lead">この8項目を埋めると、誰が見ても同じ「意味の地図」が現れます。<br/>とくにオレンジで強調された<strong>must / must_not</strong>が、輪郭をつくる芯です。</p>
      <div class="table-wrap mt-4">
        <table class="table">
          <thead><tr><th style="width:28%">フィールド</th><th>定義</th></tr></thead>
          <tbody>
            {eightFields.map((f) => (
              <tr class={f.type === 'must' ? 'row-must' : f.type === 'mustnot' ? 'row-mustnot' : ''}>
                <td><strong>{f.name}</strong></td>
                <td>{f.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- 9. 権威性 + 監修/運営元 -->
  <section class="section section--paper">
    <div class="container">
      <span class="eyebrow">Authority</span>
      <h2>設計の根拠</h2>
      <div class="notice mt-4">
        <div>
          <h3>６年以上の運用実績</h3>
          <p>Meandleは理論実装として上場企業・外資系企業のWebマーケティングにて運用してきた実績があります。SEO/AIO/リード獲得に高い効果を得ています。</p>
        </div>
        <div>
          <h3>教育現場での実装</h3>
          <p>武蔵野美術大学にて非常勤講師として、意味設計と表現の接続を実践的に指導しています。</p>
        </div>
      </div>

      <div style="margin-top:20px; padding:16px 22px; background:var(--card); border-radius:12px; border:1px solid var(--line); display:flex; flex-wrap:wrap; gap:8px 28px; align-items:baseline; font-size:14px">
        <span><strong>監修</strong>：{SUPERVISOR.name}</span>
        <span><strong>運営元</strong>：<a href={SUPERVISOR.url} rel="noopener" target="_blank" style="color:var(--brand-deep); font-weight:700; text-decoration:underline">{SUPERVISOR.org}</a></span>
        <a href="/about/" style="color:var(--brand-deep); font-weight:700; margin-left:auto">監修者・運営元について →</a>
      </div>
    </div>
  </section>

  <!-- 10. Story / Meandle が生まれた背景 -->
  <section class="section" id="story">
    <div class="container" style="max-width:820px">
      <span class="eyebrow">Story</span>
      <h2>Meandle が生まれた背景</h2>
      <p>「資料請求はある。でも商談化しない」──何十社の B2B サイトを設計・運用するなかで、繰り返し見てきた症状です。原因はトラフィックでもクリエイティブでもなく、<strong>「売るべき意味」が定義されないまま走り続けている</strong>ことでした。</p>
      <p>顧客のジョブ・シーン・代替案・比較軸を書き起こすと、売り手の言語と買い手の言語が、しばしば全く違うことが分かりました。must（決して外せない約束）と must_not（決して該当しないこと）を同じ重みで併記したとき、ようやく意味の輪郭が立ち上がりました。</p>
      <p>その実務を 8 フィールド構造として体系化したのが Meandle のはじまりです。AI 検索が情報の主な媒介者となった今、意味設計は「事業の言語そのものを整える作業」として、本来の重みを取り戻しています。2026 年 5 月、意味設計と検索文脈の整合に関する方法について特許を出願しました。</p>
      <p style="margin-top:24px; padding-top:20px; border-top:1px solid var(--line); font-size:14.5px; color:var(--ink-soft)">
