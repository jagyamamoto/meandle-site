    (function () {
      var box = document.getElementById('estimateBox');
      var out = document.getElementById('estimateResult');
      if (!box || !out) return;
      function score() {
        var target = box.querySelector('input[name="target"]:checked');
        var count = box.querySelector('input[name="count"]:checked');
        var ops = box.querySelector('input[name="ops"]:checked');
        if (!target || !count || !ops) return;
        var t = target.value, c = +count.value, o = +ops.value;
        var plan;
        if (o === 2) {
          plan = (c === 3 || t === '5') ? 'Be Meandling Full（月150万円〜）' : 'Be Meandling Basic（月60万円〜）';
        } else {
          if (c === 3 || t === '5') plan = 'Meandle Package L（500万円〜）';
          else if (c === 2) plan = 'Meandle Package M（150万円〜）';
          else plan = 'Meandle Package S（50万円〜）';
        }
        out.innerHTML = '<strong>目安：' + plan + '</strong><br/><span style="font-weight:400; font-size:13.5px; color:var(--ink-soft)">ここから先は、事業の状態を聞いたうえで個別に設計します。</span>';
      }
      box.addEventListener('change', score);
    })();</script>

